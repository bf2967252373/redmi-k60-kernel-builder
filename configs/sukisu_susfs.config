# =============================================================
# KConfig fragment: SukiSU-Ultra + SUSFS for Redmi K60 (socrates)
# Kernel: 5.10 (SM8475 / socrates-t-oss)
#
# This fragment is APPENDED to the vendor defconfig.
# After appending, `make olddefconfig` resolves any conflicts.
# =============================================================

# ---- KernelSU (SukiSU-Ultra) Core ----
CONFIG_KSU=y
# Non-GKI: use manual hook (kprobes unreliable on Qualcomm 5.10 OEM)
# CONFIG_KSU_KPROBES_HOOK is not set
CONFIG_KSU_MANUAL_HOOK=y

# ---- SUSFS (SU Filesystem) ----
CONFIG_KSU_SUSFS=y
CONFIG_KSU_SUSFS_SUS_PATH=y
CONFIG_KSU_SUSFS_SUS_MOUNT=y
CONFIG_KSU_SUSFS_AUTO_ADD_SUS_KSU_DEFAULT_MOUNT=y
CONFIG_KSU_SUSFS_AUTO_ADD_SUS_BIND_MOUNT=y
CONFIG_KSU_SUSFS_SUS_KSTAT=y
CONFIG_KSU_SUSFS_SUS_OVERLAYFS=y
CONFIG_KSU_SUSFS_TRY_UMOUNT=y
CONFIG_KSU_SUSFS_SPOOF_UNAME=y
CONFIG_KSU_SUSFS_ENABLE_LOG=y
CONFIG_KSU_SUSFS_HAS_MAGIC_MOUNT=y

# ---- Symbol tables (required for non-GKI KSU/KPM) ----
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# ---- KPM (Kernel Patch Module) -- injected dynamically if ENABLE_KPM=true ----
# CONFIG_KPM=y

# ---- Reduce debug overhead ----
# CONFIG_DYNAMIC_DEBUG is not set
# CONFIG_DEBUG_KERNEL is not set
